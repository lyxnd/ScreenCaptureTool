<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="net.jackchuan.screencapturetool.controller.EditRecordController"
            prefHeight="400.0" prefWidth="600.0"
            stylesheets="@assets/css/edit_record.css">
    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- 标题栏 -->
        <HBox styleClass="header-bar">
            <Label text="历史编辑记录" styleClass="header-title"/>
            <Label text="  |  按 Tab 关闭" styleClass="header-hint"/>
        </HBox>

        <!-- 记录列表 -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox fx:id="records" styleClass="records-box"/>
        </ScrollPane>
    </VBox>
</AnchorPane>
