<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<VBox fx:id="root" prefHeight="620.0" prefWidth="660.0"
      stylesheets="@./assets/css/setting.css"
      styleClass="setting-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="net.jackchuan.screencapturetool.controller.SettingController">

    <!-- ── 顶部操作栏 ─────────────────────────────────── -->
    <HBox styleClass="top-bar" spacing="8" alignment="CENTER_LEFT">
        <Button text="打开配置文件" styleClass="btn-top" onAction="#openConfigFile"/>
        <Button styleClass="btn-icon-top" onAction="#reloadConfig">
            <graphic><ImageView fitHeight="18" fitWidth="18"><Image url="@../screencapturetool/assets/icon/reload.png"/></ImageView></graphic>
            <tooltip><Tooltip text="重新从文件加载配置"/></tooltip>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Shift + F8  打开设置" styleClass="top-bar-hint"/>
        <Button styleClass="btn-icon-top" onAction="#exitProgram">
            <graphic><ImageView fitHeight="18" fitWidth="18"><Image url="@../screencapturetool/assets/icon/close.png"/></ImageView></graphic>
            <tooltip><Tooltip text="退出程序"/></tooltip>
        </Button>
    </HBox>

    <!-- ── 主内容区（可滚动）────────────────────────── -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox spacing="12" style="-fx-padding: 14;">

            <!-- ── 卡片：保存与路径配置 ─────────────── -->
            <VBox styleClass="card">
                <HBox styleClass="card-header">
                    <Label text="路径配置" styleClass="card-title"/>
                </HBox>
                <VBox styleClass="card-body" spacing="6">
                    <!-- 保存操作 -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="配置文件：" styleClass="path-label"/>
                        <TextField fx:id="savePath" editable="false" styleClass="path-field" HBox.hgrow="ALWAYS"/>
                        <Button text="另存为" styleClass="btn-secondary" onAction="#saveAsFile"/>
                        <Button text="保存到原路径" styleClass="btn-primary" onAction="#saveOnOriginalPath"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="EXE 目录：" styleClass="path-label"/>
                        <TextField fx:id="exePath" editable="false" styleClass="path-field" HBox.hgrow="ALWAYS"/>
                        <Button text="更改" styleClass="btn-secondary" onAction="#locateExePath"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="OCR 数据目录：" styleClass="path-label"/>
                        <TextField fx:id="ocrDataPath" editable="false" styleClass="path-field" HBox.hgrow="ALWAYS"/>
                        <Button text="更改" styleClass="btn-secondary" onAction="#locateOCRPath"/>
                        <Button text="从 Zip 安装" styleClass="btn-secondary" onAction="#unzipFromLocal"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="日志目录：" styleClass="path-label"/>
                        <TextField fx:id="logPath" editable="false" styleClass="path-field" HBox.hgrow="ALWAYS"/>
                        <Button text="更改" styleClass="btn-secondary" onAction="#changeLogPath"/>
                        <Button text="删除日志" styleClass="btn-danger" onAction="#clearLogs"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="截图保存目录：" styleClass="path-label"/>
                        <TextField fx:id="captureSavePath" editable="false" styleClass="path-field" HBox.hgrow="ALWAYS"/>
                        <Button text="更改" styleClass="btn-secondary" onAction="#locateCaptureSavePath"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ── 卡片：截图设置 ────────────────────── -->
            <VBox styleClass="card">
                <HBox styleClass="card-header">
                    <Label text="截图设置" styleClass="card-title"/>
                </HBox>
                <VBox styleClass="card-body" spacing="10">
                    <!-- 截图快捷键 -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="截图快捷键：" styleClass="path-label"/>
                        <Button fx:id="changeKeyBind" styleClass="key-btn" onAction="#changeKeyBinding" prefHeight="28"/>
                        <Label text="+" style="-fx-text-fill:#999;"/>
                        <RadioButton fx:id="isShiftNeeded" styleClass="mod-radio" text="Shift" onAction="#changeKeyBinding">
                            <toggleGroup><ToggleGroup fx:id="toggleGroup"/></toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="isAltNeeded"   styleClass="mod-radio" text="Alt"   toggleGroup="$toggleGroup" onAction="#changeKeyBinding"/>
                        <RadioButton fx:id="isCtrlNeeded"  styleClass="mod-radio" text="Ctrl"  toggleGroup="$toggleGroup" onAction="#changeKeyBinding"/>
                    </HBox>
                    <!-- 上传快捷键 -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="上传快捷键：" styleClass="path-label"/>
                        <Button fx:id="changeUploadKeyBind" styleClass="key-btn" onAction="#changeUploadKeyBinding" prefHeight="28"/>
                        <Label text="+" style="-fx-text-fill:#999;"/>
                        <RadioButton fx:id="uploadIsShiftNeeded" styleClass="mod-radio" text="Shift" onAction="#changeKeyBinding">
                            <toggleGroup><ToggleGroup fx:id="toggleGroup1"/></toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="uploadIsAltNeeded"  styleClass="mod-radio" text="Alt"  toggleGroup="$toggleGroup1" onAction="#changeKeyBinding"/>
                        <RadioButton fx:id="uploadIsCtrlNeeded" styleClass="mod-radio" text="Ctrl" toggleGroup="$toggleGroup1" onAction="#changeKeyBinding"/>
                    </HBox>
                    <!-- 截图方法 -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="截图方法：" styleClass="path-label"/>
                        <ComboBox fx:id="captureType" styleClass="setting-combo" value="JNA" prefHeight="28">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="java awt Robot"/>
                                    <String fx:value="javafx Robot"/>
                                    <String fx:value="Python's pillow"/>
                                    <String fx:value="JNA"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>
                    <!-- 行为选项 -->
                    <HBox spacing="4" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                        <CheckBox fx:id="autoCopy"     styleClass="opt-check" text="截图后自动复制"/>
                        <CheckBox fx:id="autoSelect"   styleClass="opt-check" text="自动识别截取区域"/>
                        <CheckBox fx:id="autoLaunch"   styleClass="opt-check" text="开机自启动"/>
                        <CheckBox fx:id="scaleOnMouse" styleClass="opt-check" text="鼠标处缩放"/>
                        <CheckBox fx:id="popSetting"   styleClass="opt-check" text="启动时弹出设置"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ── 卡片：快捷键开关 ──────────────────── -->
            <TitledPane fx:id="keys" styleClass="titled-pane-card" text="快捷键开关" animated="true">
                <VBox fx:id="setBox">
                    <HBox styleClass="shortcut-parent" alignment="CENTER_LEFT" spacing="12">
                        <Label text="启用全部快捷键" styleClass="shortcut-label"/>
                        <CheckBox fx:id="enableAll" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="保存 / 导出     Ctrl + S" styleClass="shortcut-label"/>
                        <CheckBox fx:id="export" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="复制到剪切板   Ctrl + C" styleClass="shortcut-label"/>
                        <CheckBox fx:id="copy" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="撤销            Ctrl + Z" styleClass="shortcut-label"/>
                        <CheckBox fx:id="undo" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="重做            Ctrl + Y" styleClass="shortcut-label"/>
                        <CheckBox fx:id="redo" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="重置所有操作   Ctrl + R" styleClass="shortcut-label"/>
                        <CheckBox fx:id="reset" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="粘贴图片        Ctrl + V" styleClass="shortcut-label"/>
                        <CheckBox fx:id="paste" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="清除历史记录   Shift + Delete" styleClass="shortcut-label"/>
                        <CheckBox fx:id="clearHistory" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="拖动图片        Alt + 鼠标" styleClass="shortcut-label"/>
                        <CheckBox fx:id="drag" onAction="#updateSettings"/>
                    </HBox>
                    <HBox styleClass="shortcut-child" alignment="CENTER_LEFT" spacing="12">
                        <Label text="橡皮模式        Shift + 鼠标" styleClass="shortcut-label"/>
                        <CheckBox fx:id="rubber" onAction="#updateSettings"/>
                    </HBox>
                </VBox>
            </TitledPane>

        </VBox>
    </ScrollPane>

    <!-- ── 状态栏 ─────────────────────────────────── -->
    <HBox styleClass="status-bar">
        <Label fx:id="state" styleClass="status-label"/>
    </HBox>
</VBox>